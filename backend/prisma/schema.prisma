generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  TEAM_MEMBER

  @@map("user_role")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD

  @@map("project_status")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE

  @@map("task_status")
}

model User {
  id               String          @id @default(uuid()) @db.Uuid
  name             String          @db.VarChar(255)
  email            String          @unique @db.VarChar(255)
  password         String          @map("password_hash") @db.VarChar(255)
  role             Role            @default(TEAM_MEMBER)
  
  // Relations
  managedProjects  Project[]       @relation("ProjectManager")
  assignedTasks    Task[]          @relation("TaskAssignee")
  memberOfProjects ProjectMember[]
  
  createdAt        DateTime?       @default(now()) @map("created_at") @db.Timestamp()
  updatedAt        DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("users")
}

model Project {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @db.VarChar(255)
  description String?         @db.Text
  status      ProjectStatus?  @default(ACTIVE)
  
  // Relations
  managerId   String          @map("manager_id") @db.Uuid
  manager     User            @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Cascade)
  tasks       Task[]
  members     ProjectMember[]
  
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("projects")
}

model ProjectMember {
  projectId String    @map("project_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  joinedAt  DateTime? @default(now()) @map("joined_at") @db.Timestamp()

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Task {
  id          String      @id @default(uuid()) @db.Uuid
  title       String      @db.VarChar(255)
  description String?     @db.Text
  status      TaskStatus? @default(TODO)
  
  // Relations
  projectId   String      @map("project_id") @db.Uuid
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assigneeId  String?     @map("assignee_id") @db.Uuid
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamp()

  @@map("tasks")
}
